{
    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["clock"],
    "modules-right": ["custom/cheatsheet", "custom/power", "battery"],

    "hyprland/workspaces": {
        "format": "{icon}"
    },

    "custom/cheatsheet": {
        "format": " ❔ ",
        "tooltip": "Cheatsheet",
        "on-click": "kitty sh -c 'glow ~/.config/hypr/cheatsheet.md | less -R'"
    },

    "custom/power": {
        "format": " ⏻ ",
        "tooltip": "Logout / Power Menu",
        "on-click": "wofi --show drun -p 'Power'"
    },

    "clock": {
        "format": "{:%H:%M}"
    }
}
