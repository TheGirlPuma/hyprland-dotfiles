{
    "@import": "mocha.css",

    "output": ["DP-1", "HDMI-A-1"],
    "layer": "top",
    "position": "top",
    "height": 50,

    "modules-left": ["custom/launcher", "hyprland/workspaces", "custom/new-workspace", "hyprland/window", "hyprland/window#hdmi"],
    "modules-center": ["clock", "custom/media"],
    "modules-right": ["custom/help", "pulseaudio", "network", "cpu", "memory", "battery", "bluetooth", "tray", "custom/power"],

    "custom/launcher": {
        "output": ["DP-1"],
        "format": "ґ░А╗",
        "tooltip": "Apps ├╢ffnen (Super + D)",
        "on-click": "rofi -show drun -theme ~/.config/rofi/spotlight-dark.rasi",
        "on-click-right": "pkill rofi",
        "class": "launcher"
    },

    "hyprland/workspaces": {
        "output": ["DP-1"],
        "all-outputs": true,
        "format": "{name}",
        "sort-by": "number",
        "persistent-workspaces": {
            "*": 2
        }
    },

    "custom/new-workspace": {
        "output": ["DP-1"],
        "format": "+",
        "tooltip": "Neuer Desktop (Strg+Super+D)",
        "on-click": "hyprctl dispatch workspace empty"
    },

    "custom/help": {
        "output": ["DP-1"],
        "format": "ґ░Ше",
        "tooltip": "Shortcuts-Haftnotiz (Super+H)",
        "on-click": "~/.config/hypr/scripts/shortcuts-help.sh"
    },

    "hyprland/window": {
        "output": ["DP-1"],
        "format": "  {}  ",
        "max-length": 60
    },

    "hyprland/window#hdmi": {
        "output": ["HDMI-A-1"],
        "format": "  {}  ",
        "max-length": 50
    },

    "clock": {
        "output": ["DP-1"],
        "format": "{:%H:%M}",
        "interval": 60
    },

    "custom/media": {
        "output": ["DP-1"],
        "exec": "playerctl metadata --format '{{artist}} - {{title}}' 2>/dev/null || echo 'No media'",
        "format": "яАБ  {}",
        "max-length": 40,
        "on-click": "playerctl play-pause"
    },

    "pulseaudio": {
        "output": ["DP-1"],
        "format": "{icon} {volume}%",
        "format-muted": "ґ░ЭЯ",
        "format-icons": ["яАж", "яАз", "яАи"],
        "tooltip-format": "{desc}",
        "on-click": "pavucontrol",
        "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "class": "audio"
    },

    "network": {
        "output": ["DP-1"],
        "format-wifi": "яЗл",
        "format-ethernet": "ґ░ИА",
        "format-disconnected": "ґ░дн"
    },

    "cpu": {
        "output": ["DP-1"],
        "format": "яЛЫ {usage}%"
    },

    "memory": {
        "output": ["DP-1"],
        "format": "яГЙ {percentage}%"
    },

    "battery": {
        "output": ["DP-1"],
        "format": "{capacity}% {icon}",
        "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
    },

    "bluetooth": {
        "output": ["DP-1"],
        "format": "яКФ",
        "format-connected": "яКФ"
    },

    "tray": {
        "output": ["DP-1"],
        "spacing": 10,
        "icon-size": 18
    },

    "custom/power": {
        "output": ["DP-1"],
        "format": "тП╗",
        "on-click": "wlogout"
    }
}