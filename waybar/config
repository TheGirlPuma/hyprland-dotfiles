{
    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["clock"],
    "modules-right": ["custom/launcher", "custom/cheatsheet", "custom/power", "battery"],

    "hyprland/workspaces": {
        "format": "{icon}"
    },

    "custom/launcher": {
        "format": "󰀻",
        "tooltip": "App-Menü (9-Punkte)",
        "on-click": "wofi --show drun --normal-window"
    },

    "custom/cheatsheet": {
        "format": " ❔ ",
        "tooltip": "Cheatsheet",
        "on-click": "kitty sh -c 'glow ~/.config/hypr/cheatsheet.md | less -R'"
    },

    "custom/power": {
        "format": " ⏻ ",
        "tooltip": "Power Menu",
        "on-click": "~/.config/hypr/power-menu.sh"
    },

    "clock": {
        "format": "{:%H:%M}"
    }
}
